# Copy this file to .deploy.env and fill in your server values.
# .deploy.env is ignored by git and is only for your local machine.

# Required: SSH target for your server.
NEW_API_HOST=root@1.2.3.4

# Optional: SSH port. Leave empty for 22.
NEW_API_SSH_PORT=

# Required: remote directory where the app will live.
NEW_API_PATH=/opt/new-api

# Required for generating .env.production.
# Use https://your-domain.example when DNS already points to the server.
# Use http://your-server-ip when deploying without a domain first.
PUBLIC_URL=https://api.example.com
